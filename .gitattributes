# Set the default behavior, in case people don't have core.autocrlf set.
* text=auto eol=lf

# Explicitly declare text files you want to always have LF line endings
# on checkout, regardless of the platform.
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.css text eol=lf
*.js text eol=lf

# Declare files that will always have CRLF line endings on checkout.
*.bat text eol=crlf